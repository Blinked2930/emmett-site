---
import Footer from '../components/Footer.astro';
import ContactBlock from '../components/ContactBlock.astro';
import '../styles/global.css';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
}

const { title = 'Emmett Frett' } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Logic to build the URL for the language toggle switch
let currentPath = Astro.url.pathname;
if (currentPath.startsWith('/sq/')) {
  currentPath = currentPath.replace('/sq/', '/');
} else if (currentPath === '/sq') {
  currentPath = '/';
}
const isHome = currentPath === '/' || currentPath === '/sq' || currentPath === '/sq/';
const togglePath = lang === 'en' ? `/sq${currentPath === '/' ? '' : currentPath}` : currentPath;
const toggleText = lang === 'en' ? 'Shqip (SQ)' : 'English (EN)';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Emmett Frett - Exploring the world, building systems, and documenting the work." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@400;500;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-white text-zinc-900 antialiased">
    
    {/* Language Toggle and Nav */}
    <div id="header-nav-container" class={`z-50 transition-all duration-500 ${isHome ? 'absolute md:fixed top-6 md:left-1/2 md:-translate-x-1/2 md:opacity-60 hover:opacity-100 w-full md:w-auto px-6 md:px-0 flex justify-end md:block' : 'absolute top-6 right-6'}`}>
      
      {isHome ? (
        <>
          {/* Desktop Nav Pill */}
          <nav class="hidden md:flex items-center bg-zinc-900/80 backdrop-blur-md border border-zinc-700/50 shadow-2xl rounded-full p-1.5 gap-1">
            <a href={lang === 'en' ? "#showcase" : "/sq#showcase"} class="font-['Inter'] flex items-center gap-1.5 text-[10px] font-bold tracking-[0.2em] uppercase bg-zinc-100 text-zinc-900 hover:bg-white px-5 py-2.5 rounded-full transition-all">
              Projects <span class="text-xs leading-none">&darr;</span>
            </a>
            <a href={lang === 'en' ? "/cv" : "/sq/cv"} class="font-['Inter'] flex items-center gap-1.5 text-[10px] font-bold tracking-[0.2em] uppercase text-zinc-300 hover:text-white hover:bg-zinc-800 px-5 py-2.5 rounded-full transition-all">
              CV <span class="text-xs leading-none opacity-50">&nearr;</span>
            </a>
            <a href={lang === 'en' ? "/essays" : "/sq/essays"} class="font-['Inter'] flex items-center gap-1.5 text-[10px] font-bold tracking-[0.2em] uppercase text-zinc-300 hover:text-white hover:bg-zinc-800 px-5 py-2.5 rounded-full transition-all">
              Essays <span class="text-xs leading-none opacity-50">&nearr;</span>
            </a>
            <div class="w-px h-4 bg-zinc-700 mx-2"></div>
            <a href={togglePath} class="font-['Inter'] text-[10px] font-bold tracking-[0.2em] uppercase text-zinc-300 hover:text-white hover:bg-zinc-800 px-6 py-2.5 rounded-full transition-all">
              {toggleText}
            </a>
          </nav>
          {/* Mobile Language Toggle */}
          <a href={togglePath} class="md:hidden font-['Inter'] text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-500 px-4 py-2 border border-zinc-200 bg-white/80 backdrop-blur-sm rounded-sm hover:bg-zinc-100 hover:text-zinc-900 transition-colors shadow-sm flex items-center">
            {toggleText}
          </a>
        </>
      ) : (
        <a href={togglePath} class="font-['Inter'] text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-500 px-4 py-2 border border-zinc-200 bg-white/80 backdrop-blur-sm rounded-sm hover:bg-zinc-100 hover:text-zinc-900 transition-colors shadow-sm flex items-center">
          {toggleText}
        </a>
      )}
    </div>

    {/* This slot is the magic portal where your Home.astro content appears */}
    <slot />
    
    <ContactBlock />

    {/* The dynamically translated footer we just built */}
    <Footer />

    {/* The Glide animation engine */}
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('glide-in');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('.glide').forEach((el) => {
          observer.observe(el);
        });

        // Scroll listener for header nav opacity on home page
        document.addEventListener('scroll', () => {
          const headerNav = document.getElementById('header-nav-container');
          if (headerNav && headerNav.classList.contains('md:fixed')) {
            if (window.scrollY > 100) {
              headerNav.classList.remove('md:opacity-50');
            } else {
              headerNav.classList.add('md:opacity-50');
            }
          }
        });
      });
    </script>
  </body>
</html>