---
import Footer from '../components/Footer.astro';
import ContactBlock from '../components/ContactBlock.astro';
import '../styles/global.css';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
}

const { title = 'Emmett Frett' } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Logic to build the URL for the language toggle switch
let currentPath = Astro.url.pathname;
if (currentPath.startsWith('/sq/')) {
  currentPath = currentPath.replace('/sq/', '/');
} else if (currentPath === '/sq') {
  currentPath = '/';
}
const isHome = currentPath === '/' || currentPath === '/sq' || currentPath === '/sq/';
const togglePath = lang === 'en' ? `/sq${currentPath === '/' ? '' : currentPath}` : currentPath;
const toggleText = lang === 'en' ? 'Shqip (SQ)' : 'English (EN)';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Emmett Frett - Exploring the world, building systems, and documenting the work." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@400;500;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-white text-zinc-900 antialiased">
    
    {/* Language Toggle */}
    <div id="lang-toggle-container" class={`z-50 transition-all duration-500 ${isHome ? 'absolute md:fixed top-6 right-6 md:opacity-50 hover:opacity-100' : 'absolute top-6 right-6'}`}>
      <a href={togglePath} class="font-['Inter'] text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-500 px-4 py-2 border border-zinc-200 bg-white/80 backdrop-blur-sm rounded-sm hover:bg-zinc-100 hover:text-zinc-900 transition-colors shadow-sm flex items-center h-[34px]">
        {toggleText}
      </a>
    </div>

    {/* This slot is the magic portal where your Home.astro content appears */}
    <slot />
    
    <ContactBlock />

    {/* The dynamically translated footer we just built */}
    <Footer />

    {/* The Glide animation engine */}
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('glide-in');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('.glide').forEach((el) => {
          observer.observe(el);
        });

        // Scroll listener for language toggle opacity on home page
        document.addEventListener('scroll', () => {
          const langToggle = document.getElementById('lang-toggle-container');
          if (langToggle && langToggle.classList.contains('md:fixed')) {
            if (window.scrollY > 100) {
              langToggle.classList.remove('md:opacity-50');
            } else {
              langToggle.classList.add('md:opacity-50');
            }
          }
        });
      });
    </script>
  </body>
</html>