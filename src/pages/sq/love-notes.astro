---
import Layout from '../../layouts/Layout.astro';

import fs from 'node:fs';
import path from 'node:path';

// We'll use your two folded note photos as "Process" images
const processImages = [
  '/love-notes/folded-sq-1.jpeg',
  '/love-notes/folded-sq-2.jpeg'
];

// Calculate notes stats dynamically
const notesDir = path.join(process.cwd(), 'public', 'love-notes');
let totalNotes = 226; // fallback
let noteFiles: string[] = [];
try {
  const files = fs.readdirSync(notesDir);
  noteFiles = files.filter((f: string) => f.endsWith('.jpeg') && !f.startsWith('folded'));
  if (noteFiles.length > 0) {
    totalNotes = noteFiles.length;
  }
} catch (e) {
  console.error("Error reading love-notes directory", e);
}

const minutesPerNote = 7;
const totalMinutes = totalNotes * minutesPerNote;
const totalHours = Math.round(totalMinutes / 60);

// Helper for formatting numbers with commas
const formatNumber = (num: number) => new Intl.NumberFormat('en-US').format(num);
---

<Layout title="Nga Një I Huaj | Emmett Frett">
	<!-- Hero Section -->
	<section class="relative min-h-[60vh] flex flex-col justify-center overflow-hidden bg-zinc-900 group py-24">
		<div class="absolute inset-0 z-0">
			<!-- A warm analog background to evoke parchment or amber streetlights -->
			<div class="absolute inset-0 bg-gradient-to-br from-amber-900/40 via-zinc-900 to-orange-900/20"></div>
            <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:24px_24px]"></div>
		</div>

		<div class="relative z-10 flex flex-col items-center justify-center text-center px-6 max-w-5xl mx-auto glide pt-10">
			<a href="/sq" class="text-amber-200/60 hover:text-amber-100 transition-colors duration-300 font-['Inter'] text-sm tracking-widest uppercase mb-16 inline-flex items-center gap-2 font-bold z-20">
				&larr; Kthehu në Kryefaqe
			</a>
			<h1 class="font-['Montserrat'] font-black text-5xl sm:text-6xl md:text-7xl text-white mb-6 tracking-tight drop-shadow-xl">
				Nga Një I Huaj
			</h1>
			
			<p class="font-['Inter'] text-lg sm:text-xl md:text-2xl text-amber-100/70 font-light max-w-3xl leading-relaxed mx-auto mb-16">
				Në një epokë të konsumit pasiv, lë mesazhe të shkruara me dorë prej 30 fjalësh në vendet që udhëtoj. Pa kontekst, pa axhendë—vetëm një <span class="font-semibold text-white">kryqëzim i shkurtër i dy jetëve.</span>
			</p>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 w-full max-w-4xl mx-auto px-4 mt-8">
                <!-- Glassmorphism stat cards -->
                <div class="bg-white/5 border border-white/10 backdrop-blur-md rounded-2xl p-6 flex flex-col items-center justify-center shadow-2xl hover:bg-white/10 transition-colors duration-300">
                    <span class="block font-['Montserrat'] font-black text-4xl text-white mb-2">{formatNumber(totalNotes)}</span>
                    <span class="font-['Inter'] text-[10px] uppercase tracking-[0.2em] text-amber-200/50 font-bold">Totali I Shënimeve</span>
                </div>
                <div class="bg-white/5 border border-white/10 backdrop-blur-md rounded-2xl p-6 flex flex-col items-center justify-center shadow-2xl hover:bg-white/10 transition-colors duration-300">
                    <span class="block font-['Montserrat'] font-black text-4xl text-white mb-2">{formatNumber(totalMinutes)}</span>
                    <span class="font-['Inter'] text-[10px] uppercase tracking-[0.2em] text-amber-200/50 font-bold">Minuta Të Shpenzuara</span>
                </div>
                <div class="bg-white/5 border border-white/10 backdrop-blur-md rounded-2xl p-6 flex flex-col items-center justify-center shadow-2xl hover:bg-white/10 transition-colors duration-300">
                    <span class="block font-['Montserrat'] font-black text-4xl text-white mb-2">~{formatNumber(totalHours)}</span>
                    <span class="font-['Inter'] text-[10px] uppercase tracking-[0.2em] text-amber-200/50 font-bold">Orë Krijimi</span>
                </div>
            </div>
		</div>
	</section>

	<main class="bg-zinc-50 py-24 px-4 sm:px-6 lg:px-8 relative">
        <div class="max-w-7xl mx-auto">

    <section class="mb-32">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {processImages.map((img) => (
          <div class="glide aspect-video overflow-hidden rounded-sm bg-zinc-200 grayscale contrast-125">
             <img 
               src={img} 
               alt="Handwritten notes folded and ready to be left" 
               class="w-full h-full object-cover opacity-90"
             />
          </div>
        ))}
      </div>
      <p class="mt-6 font-['Inter'] text-zinc-400 text-sm italic text-center">
        Çdo shënim paloset me dorë, duke u siguruar që të gjithë të ndiejnë thjeshtësinë e dashurisë.
      </p>
    </section>

    <div id="notes-grid" class="grid grid-cols-1 md:grid-cols-2 gap-16">
      </div>

    <div class="mt-24 text-center glide">
      <button 
        onclick="reloadAndScroll()" 
        class="px-8 py-4 bg-zinc-900 border border-zinc-900 text-white hover:bg-zinc-800 transition-all duration-300 rounded-full font-['Inter'] text-xs font-bold tracking-[0.2em] uppercase shadow-xl hover:shadow-2xl hover:-translate-y-1"
      >
        Shiko Shënime Të Reja
      </button>
    </div>
    </div>
  </main>
</Layout>

<script define:vars={{ noteFiles }}>
  function renderRandomNotes() {
    const DISPLAY_COUNT = 8; 
    const grid = document.getElementById('notes-grid');
    if (!grid) return;
    
    const files = [...noteFiles];
    
    for (let i = files.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [files[i], files[j]] = [files[j], files[i]];
    }
    
    const selected = files.slice(0, DISPLAY_COUNT);
    
    selected.forEach((filename, index) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'glide aspect-[4/3] overflow-hidden bg-white rounded-sm border border-zinc-200 shadow-sm group';
      wrapper.style.transitionDelay = `${index * 0.1}s`;
      
      // --- THE MATHEMATICAL BRIDGE FIX IS HERE ---
      wrapper.innerHTML = `
        <img 
          src="/love-notes/${filename}" 
          alt="Handwritten note" 
          class="w-full h-full object-contain bg-zinc-100 opacity-80 grayscale contrast-125 brightness-100 group-hover:opacity-100 group-hover:grayscale-0 group-hover:contrast-100 group-hover:brightness-110 transition-all duration-[1000ms] ease-out cursor-pointer"
          loading="lazy"
        />
      `;
      // ----------------------------------------
      grid.appendChild(wrapper);
    });

    if (window.IntersectionObserver) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('glide-in');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      grid.querySelectorAll('.glide').forEach((el) => observer.observe(el));
    }
  }

  function reloadAndScroll() {
    const grid = document.getElementById('notes-grid');
    if (!grid) return;
    
    // Clear and re-render
    grid.innerHTML = '';
    renderRandomNotes();
    
    // Scroll back to the top of the grid smoothly
    const yOffset = -20; // adding a little breathing room
    const y = grid.getBoundingClientRect().top + window.scrollY + yOffset;
    window.scrollTo({ top: y, behavior: 'smooth' });
  }

  document.addEventListener('DOMContentLoaded', () => {
    renderRandomNotes();
    
    // Initial observer for other glide elements on page load
    if (window.IntersectionObserver) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('glide-in');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('body > main .glide, header.glide, section.glide').forEach((el) => observer.observe(el));
    }
  });
</script>