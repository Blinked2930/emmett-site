---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Logic to build the URL for the language toggle switch
let currentPath = Astro.url.pathname;
if (currentPath.startsWith("/sq/")) {
  currentPath = currentPath.replace("/sq/", "/");
} else if (currentPath === "/sq" || currentPath === "/sq/") {
  currentPath = "/";
}
const togglePath =
  lang === "en" ? `/sq${currentPath === "/" ? "" : currentPath}` : currentPath;
const toggleText = lang === "en" ? "Shqip (SQ)" : "English (EN)";
---

<footer id="footer-contact" class="border-t border-zinc-100 bg-white">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col lg:flex-row justify-between items-center gap-10">
      <div class="text-center lg:text-left glide">
        <h2
          class="font-['Inter'] text-xl md:text-2xl font-light text-zinc-900 leading-snug tracking-tight"
        >
          {t("footer.headline")}
        </h2>
      </div>

      <div
        class="flex flex-col items-center lg:items-end gap-6 w-full lg:w-auto glide"
      >
        <div class="flex items-center justify-center gap-6">
          <a
            href="/cv"
            class="whitespace-nowrap inline-block font-['Inter'] text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 hover:text-zinc-900 transition-all duration-300 hover:scale-110"
          >
            {t("footer.cv_media")}
          </a>

          <div class="w-px h-4 bg-zinc-200"></div>

          <a
            href="mailto:emmettfrett@gmail.com?subject=Hello%20from%20the%20website"
            class="text-zinc-500 hover:text-zinc-900 transition-all duration-300 hover:-translate-y-1 hover:scale-110 hover:drop-shadow-md"
            aria-label="Email"
          >
            <svg
              class="w-6 h-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </a>

          <a
            href="https://www.linkedin.com/in/emmettfrett/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-zinc-500 hover:text-[#0A66C2] transition-all duration-300 hover:-translate-y-1 hover:scale-110 hover:drop-shadow-md"
            aria-label="LinkedIn"
          >
            <svg
              class="w-6 h-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>

          <a
            href="https://substack.com/@emmettfrett"
            target="_blank"
            rel="noopener noreferrer"
            class="text-zinc-500 hover:text-[#FF6719] transition-all duration-300 hover:-translate-y-1 hover:scale-110 hover:drop-shadow-md"
            aria-label="Substack"
          >
            <svg
              class="w-6 h-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M4 5h16v3H4z"></path>
              <path d="M4 11h16v10l-8-4-8 4z"></path>
            </svg>
          </a>
        </div>

        <div class="text-center lg:text-right w-full lg:w-auto">
          <p
            class="font-['Inter'] text-[10px] uppercase tracking-[0.3em] text-zinc-400 mb-1 font-bold"
          >
            {t("footer.location")}
          </p>
          <p
            class="font-['Inter'] text-[9px] text-zinc-300 italic uppercase tracking-widest"
          >
            {t("footer.year")}
          </p>
        </div>
      </div>
    </div>

    <div
      class="mt-16 pt-8 border-t border-zinc-50 flex flex-col md:flex-row justify-between items-center gap-6"
    >
      {/* THE LANGUAGE TOGGLE BUTTON (FOOTER) */}
      <a
        href={togglePath}
        class="font-['Inter'] text-[9px] font-bold uppercase tracking-[0.3em] text-zinc-500 px-4 py-2 border border-zinc-200 rounded-sm hover:bg-zinc-100 hover:text-zinc-900 transition-colors"
      >
        {toggleText}
      </a>

      <div
        class="flex gap-6 font-['Inter'] text-[9px] uppercase tracking-[0.4em] font-medium opacity-30"
      >
        <span>&copy; 2026 Emmett Frett</span>
      </div>
    </div>
  </div>
</footer>
