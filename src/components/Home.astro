---
import Layout from '../layouts/Layout.astro';
import projects from '../data/projects.json';
import { useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
const t = useTranslations(lang);

// Reorder projects to ensure "Letters from Albania" is at the bottom
const lettersProject = projects.find(p => p.title === 'Letters from Albania');
const otherProjects = projects.filter(p => p.title !== 'Letters from Albania');
const reorderedProjects = lettersProject ? [...otherProjects, lettersProject] : projects;
---

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>

<Layout title={t('nav.title')}>
    
    <!-- Hero Section -->
    <section class="relative h-screen overflow-hidden bg-zinc-900 group">
        
        <div id="hero-slider" class="flex w-full h-full transition-transform duration-1000 ease-[cubic-bezier(0.7,0,0.3,1)]">
            <div class="min-w-full h-full relative">
                <img src="/images/albanian-sunset.jpeg" alt="Albanian Sunset" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-zinc-900/50 mix-blend-multiply"></div>
            </div>
            <div class="min-w-full h-full relative">
                <img src="/images/on-top-bunker.jpeg" alt="Sunset in Albania" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-zinc-900/50 mix-blend-multiply"></div>
            </div>
            <div class="min-w-full h-full relative">
                <img src="/images/shaking-hands.jpeg" alt="Shaking Hands" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-zinc-900/60 mix-blend-multiply"></div>
            </div>
        </div>

        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-zinc-900/60 to-zinc-50 pointer-events-none z-10"></div>

        <div class="absolute inset-0 z-20 flex flex-col items-center justify-center text-center px-6 max-w-5xl mx-auto mt-20 glide">
            <h1 class="font-['Montserrat'] font-black text-6xl sm:text-7xl md:text-8xl text-white mb-6 tracking-tight drop-shadow-[0_4px_24px_rgba(0,0,0,0.8)]">
                Emmett Frett
            </h1>
            
            <p class="font-['Inter'] text-xl sm:text-2xl md:text-3xl text-zinc-100 font-light mb-12 leading-relaxed max-w-4xl mx-auto drop-shadow-[0_4px_16px_rgba(0,0,0,0.8)]">
                <span class="font-semibold text-white tracking-wide">{t('hero.subheadline.building')}</span>
                <span class="font-semibold text-white tracking-wide">{t('hero.subheadline.community')}</span>
                <span class="font-semibold text-white tracking-wide">{t('hero.subheadline.projects')}</span>
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
                <!-- Primary CTA - Most prominent element -->
                <a 
                    href="#footer-contact" 
                    class="group w-full sm:w-auto px-10 py-5 bg-white text-zinc-900 rounded-full font-['Inter'] text-sm font-bold tracking-[0.2em] uppercase hover:bg-zinc-100 hover:scale-105 hover:shadow-[0_0_40px_rgba(255,255,255,0.4)] transition-all duration-500"
                >
                    {t('hero.btn.primary')}
                </a>
                <!-- Secondary CTA -->
                <a 
                    href="#showcase" 
                    class="group w-full sm:w-auto px-8 py-5 bg-zinc-900/30 border border-white/40 text-white rounded-full font-['Inter'] text-sm font-bold tracking-[0.2em] uppercase hover:bg-white/10 hover:border-white transition-all duration-500 backdrop-blur-sm"
                >
                    {t('hero.btn.secondary')}
                </a>
            </div>
        </div>

        <div class="absolute bottom-12 left-0 right-0 z-30 flex justify-center gap-4">
            <button class="slider-dot w-2 h-2 rounded-full bg-white transition-all duration-300 scale-150 opacity-100" data-index="0" aria-label="Slide 1"></button>
            <button class="slider-dot w-2 h-2 rounded-full bg-white opacity-40 transition-all duration-300 hover:opacity-100" data-index="1" aria-label="Slide 2"></button>
            <button class="slider-dot w-2 h-2 rounded-full bg-white opacity-40 transition-all duration-300 hover:opacity-100" data-index="2" aria-label="Slide 3"></button>
        </div>
    </section>

    <!-- Quote Section -->
    <section class="bg-zinc-50 border-b border-zinc-200 py-32 px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto flex flex-col items-center text-center glide">
            <div class="w-12 h-px bg-zinc-300 mb-8" aria-hidden="true"></div>
            <blockquote class="font-['Montserrat'] text-3xl sm:text-4xl lg:text-5xl font-medium text-zinc-800 leading-tight">
                {t('quote.text')}
            </blockquote>
            <cite class="mt-6 not-italic font-['Inter'] text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-400">
                {t('quote.author')}
            </cite>
        </div>
    </section>

    <!-- About Section -->
    <section class="py-24 px-6 bg-white border-b border-zinc-100">
        <div class="max-w-3xl mx-auto text-center glide">
            <h2 class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-6 tracking-tight">{t('about.title')}</h2>
            <p class="font-['Inter'] text-lg text-zinc-600 font-light leading-relaxed">
                {t('about.text')}
            </p>
        </div>
    </section>

    <!-- Core Capabilities (Replacing News) -->
    <section class="py-32 px-6 bg-zinc-50 border-b border-zinc-200">
        <div class="max-w-6xl mx-auto glide">
            <div class="text-center mb-20">
                <h2 class="font-['Montserrat'] text-4xl font-bold text-zinc-900 mb-4 tracking-tight">{t('capabilities.title')}</h2>
                <div class="w-16 h-1 bg-zinc-900 mx-auto rounded-full"></div>
            </div>
            
            <!-- Strict Symmetry: 2x2 Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
                <!-- Card 1 -->
                <div class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-xl transition-shadow duration-500 border border-zinc-100 group flex flex-col justify-between h-full">
                    <div>
                        <div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center mb-8 text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>
                        </div>
                        <h3 class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-4">{t('capabilities.card1.title')}</h3>
                    </div>
                    <p class="font-['Inter'] text-zinc-600 font-medium leading-relaxed bg-zinc-50 p-4 rounded-xl">
                        {t('capabilities.card1.highlight')}
                    </p>
                </div>

                <!-- Card 2 -->
                <div class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-xl transition-shadow duration-500 border border-zinc-100 group flex flex-col justify-between h-full">
                    <div>
                        <div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center mb-8 text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
                        </div>
                        <h3 class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-4">{t('capabilities.card2.title')}</h3>
                    </div>
                    <p class="font-['Inter'] text-zinc-600 font-medium leading-relaxed bg-zinc-50 p-4 rounded-xl">
                        {t('capabilities.card2.highlight')}
                    </p>
                </div>

                <!-- Card 3 -->
                <div class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-xl transition-shadow duration-500 border border-zinc-100 group flex flex-col justify-between h-full">
                    <div>
                        <div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center mb-8 text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" /></svg>
                        </div>
                        <h3 class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-4">{t('capabilities.card3.title')}</h3>
                    </div>
                    <p class="font-['Inter'] text-zinc-600 font-medium leading-relaxed bg-zinc-50 p-4 rounded-xl">
                        {t('capabilities.card3.highlight')}
                    </p>
                </div>

                <!-- Card 4 -->
                <div class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-xl transition-shadow duration-500 border border-zinc-100 group flex flex-col justify-between h-full">
                    <div>
                        <div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center mb-8 text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>
                        </div>
                        <h3 class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-4">{t('capabilities.card4.title')}</h3>
                    </div>
                    <p class="font-['Inter'] text-zinc-600 font-medium leading-relaxed bg-zinc-50 p-4 rounded-xl">
                        {t('capabilities.card4.highlight')}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Visual Showcase -->
    <section id="showcase" class="py-32 px-6 max-w-7xl mx-auto scroll-mt-20">
        <div class="mb-24 text-center glide">
            <h2 class="font-['Montserrat'] text-4xl font-bold text-zinc-900 mb-4 tracking-tight">{t('showcase.title')}</h2>
            <p class="font-['Inter'] text-zinc-500 font-light text-lg">{t('showcase.subtitle')}</p>
        </div>
        
        <!-- Asymmetrical Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 auto-rows-[400px]">
            {reorderedProjects.map((project, index) => {
                const isExternal = project.title === 'Letters from Albania';
                const bgImage = project.image || 'https://images.unsplash.com/photo-1555421689-491a97ff2040?q=80&w=2940&auto=format&fit=crop'; 
                
                // Asymmetry Logic: make the first item span 2 columns and 2 rows, others normal
                let gridSpanClass = "col-span-1 row-span-1";
                if (index === 0) {
                    gridSpanClass = "md:col-span-2 md:row-span-2";
                } else if (isExternal) {
                    gridSpanClass = "md:col-span-2 lg:col-span-2";
                }

                return (
                    <a
                        href={lang === 'sq' && !isExternal ? `/sq${project.link}` : project.link}
                        target={isExternal ? '_blank' : undefined}
                        rel={isExternal ? 'noopener noreferrer' : undefined}
                        class={`glide group relative flex flex-col justify-end overflow-hidden bg-zinc-900 rounded-2xl hover:-translate-y-2 transition-all duration-500 hover:shadow-2xl cursor-pointer no-underline text-inherit ${gridSpanClass}`}
                    >
                        <img src={bgImage} alt={project.title} class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-60 group-hover:scale-105 transition-transform duration-700 ease-out" />
                        <div class="absolute inset-0 bg-gradient-to-t from-zinc-900/90 via-zinc-900/40 to-transparent"></div>
                        
                        <div class="relative z-10 p-8 md:p-10">
                            <h3 class={`font-['Montserrat'] font-bold text-white mb-3 ${index === 0 ? 'text-3xl md:text-5xl' : 'text-2xl'}`}>
                                {lang === 'sq' && project.title_sq ? project.title_sq : project.title}
                            </h3>
                            <p class={`font-['Inter'] text-zinc-300 font-light leading-relaxed mb-8 max-w-lg ${index === 0 ? 'text-lg line-clamp-3' : 'text-base line-clamp-2'}`}>
                                {lang === 'sq' && project.description_sq ? project.description_sq : project.description}
                            </p>
                            <div class="flex items-center text-xs font-bold font-['Inter'] uppercase tracking-[0.2em] text-white/80 group-hover:text-white transition-colors duration-300 bg-white/10 w-fit px-5 py-3 rounded-full backdrop-blur-md">
                                {t('showcase.explore')} <span class="ml-3 group-hover:translate-x-1 transition-transform duration-300">&rarr;</span>
                            </div>
                        </div>
                    </a>
                );
            })}
        </div>
    </section>

    <!-- Testimonials (Social Proof) Section -->
    <section class="py-32 px-6 bg-zinc-900 text-zinc-50 border-t border-zinc-800">
        <div class="max-w-7xl mx-auto glide">
            <div class="text-center mb-20">
                <h2 class="font-['Montserrat'] text-4xl font-bold text-white mb-4 tracking-tight">{t('testimonials.title')}</h2>
                <div class="w-16 h-1 bg-zinc-700 mx-auto rounded-full"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Testimonial 1 -->
                <div class="bg-zinc-800/50 rounded-3xl p-10 border border-zinc-700/50 flex flex-col justify-between h-full hover:bg-zinc-800 transition-colors duration-500">
                    <p class="font-['Inter'] text-lg text-zinc-300 font-light leading-relaxed italic mb-10 relative">
                        <span class="absolute -top-6 -left-4 text-6xl text-zinc-700 opacity-50 font-['Montserrat']">"</span>
                        {t('testimonials.quote1.text')}
                    </p>
                    <div class="flex items-center gap-4 mt-auto">
                        <img src="/images/placeholder-face.jpg" class="w-12 h-12 rounded-full object-cover border-2 border-zinc-700" alt="Stacie Bosley" />
                        <div>
                            <p class="font-['Montserrat'] font-bold text-white text-sm">Stacie Bosley</p>
                            <p class="font-['Inter'] text-xs text-zinc-400">Professor & Kahlert Chair of Economics</p>
                        </div>
                    </div>
                </div>

                <!-- Testimonial 2 -->
                <div class="bg-zinc-800/50 rounded-3xl p-10 border border-zinc-700/50 flex flex-col justify-between h-full hover:bg-zinc-800 transition-colors duration-500">
                    <p class="font-['Inter'] text-lg text-zinc-300 font-light leading-relaxed italic mb-10 relative">
                        <span class="absolute -top-6 -left-4 text-6xl text-zinc-700 opacity-50 font-['Montserrat']">"</span>
                        {t('testimonials.quote2.text')}
                    </p>
                    <div class="flex items-center gap-4 mt-auto">
                        <img src="/images/placeholder-face.jpg" class="w-12 h-12 rounded-full object-cover border-2 border-zinc-700" alt="Xanthi Gerasimo" />
                        <div>
                            <p class="font-['Montserrat'] font-bold text-white text-sm">Xanthi Gerasimo</p>
                            <p class="font-['Inter'] text-xs text-zinc-400">Mentor & Academic Advisor</p>
                        </div>
                    </div>
                </div>

                <!-- Testimonial 3 -->
                <div class="bg-zinc-800/50 rounded-3xl p-10 border border-zinc-700/50 flex flex-col justify-between h-full hover:bg-zinc-800 transition-colors duration-500">
                    <p class="font-['Inter'] text-lg text-zinc-300 font-light leading-relaxed italic mb-10 relative">
                        <span class="absolute -top-6 -left-4 text-6xl text-zinc-700 opacity-50 font-['Montserrat']">"</span>
                        {t('testimonials.quote3.text')}
                    </p>
                    <div class="flex items-center gap-4 mt-auto">
                        <img src="/images/placeholder-face.jpg" class="w-12 h-12 rounded-full object-cover border-2 border-zinc-700" alt="Kim Lartz" />
                        <div>
                            <p class="font-['Montserrat'] font-bold text-white text-sm">Kim Lartz</p>
                            <p class="font-['Inter'] text-xs text-zinc-400">Scenic Designer & Professor</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const slider = document.getElementById('hero-slider');
            if (slider) {
                const dots = document.querySelectorAll('.slider-dot');
                const slideCount = dots.length;
                let currentIndex = 0;
                let interval;

                function goToSlide(index) {
                    slider.style.transform = `translateX(-${index * 100}%)`;
                    dots.forEach((dot, i) => {
                        if (i === index) {
                            dot.classList.replace('opacity-40', 'opacity-100');
                            dot.classList.add('scale-150');
                        } else {
                            dot.classList.replace('opacity-100', 'opacity-40');
                            dot.classList.remove('scale-150');
                        }
                    });
                    currentIndex = index;
                }

                function nextSlide() {
                    goToSlide((currentIndex + 1) % slideCount);
                }

                function startAutoplay() {
                    interval = setInterval(nextSlide, 5000); 
                }

                function resetAutoplay() {
                    clearInterval(interval);
                    startAutoplay();
                }

                dots.forEach((dot, index) => {
                    dot.addEventListener('click', () => {
                        goToSlide(index);
                        resetAutoplay();
                    });
                });

                startAutoplay();
            }
        });
    </script>
</Layout>