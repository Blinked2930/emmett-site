---
import Layout from "../layouts/Layout.astro";
import projects from "../data/projects.json";
import { useTranslations } from "../i18n/utils";

const { lang } = Astro.props;
const t = useTranslations(lang);

// Make "Letters from Albania" the primary featured project (index 0)
const lettersProject = projects.find((p) => p.title === "Letters from Albania");
const otherProjects = projects.filter(
    (p) => p.title !== "Letters from Albania",
);
const reorderedProjects = lettersProject
    ? [lettersProject, ...otherProjects]
    : projects;
---

<style is:global>
    html {
        scroll-behavior: smooth;
    }
</style>

<Layout title={t("nav.title")}>
    <section class="relative h-screen overflow-hidden bg-zinc-900 group">
        <div
            id="hero-slider"
            class="flex w-full h-full transition-transform duration-1000 ease-[cubic-bezier(0.7,0,0.3,1)]"
        >
            <div class="min-w-full h-full relative">
                <img
                    src="/images/albanian-sunset.jpeg"
                    alt="Albanian Sunset"
                    class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 bg-zinc-900/50 mix-blend-multiply">
                </div>
            </div>
            <div class="min-w-full h-full relative">
                <img
                    src="/images/on-top-bunker.jpeg"
                    alt="Sunset in Albania"
                    class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 bg-zinc-900/50 mix-blend-multiply">
                </div>
            </div>
            <div class="min-w-full h-full relative">
                <img
                    src="/images/shaking-hands.jpeg"
                    alt="Shaking Hands"
                    class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 bg-zinc-900/60 mix-blend-multiply">
                </div>
            </div>
        </div>

        <div
            class="absolute inset-0 bg-gradient-to-b from-transparent via-zinc-900/60 to-zinc-50 pointer-events-none z-10"
        >
        </div>

        <div
            class="absolute inset-0 z-20 flex flex-col items-center justify-center text-center px-6 max-w-5xl mx-auto mt-20 glide"
        >
            <h1
                class="font-['Montserrat'] font-black text-6xl sm:text-7xl md:text-8xl text-white mb-6 tracking-tight drop-shadow-[0_4px_24px_rgba(0,0,0,0.8)]"
            >
                Emmett Frett
            </h1>

            <p
                class="font-['Inter'] text-xl sm:text-2xl md:text-3xl text-zinc-100 font-light mb-12 leading-relaxed max-w-4xl mx-auto drop-shadow-[0_4px_16px_rgba(0,0,0,0.8)]"
            >
                <span class="font-semibold text-white tracking-wide"
                    >{t("hero.subheadline.building")}</span
                >
                <span class="font-semibold text-white tracking-wide"
                    >{t("hero.subheadline.community")}</span
                >
                <span class="font-semibold text-white tracking-wide"
                    >{t("hero.subheadline.projects")}</span
                >
            </p>

            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-6"
            >
                <a
                    href="#contact"
                    class="group w-full sm:w-auto px-10 py-5 bg-white text-zinc-900 rounded-full font-['Inter'] text-sm font-bold tracking-[0.2em] uppercase hover:bg-zinc-100 hover:scale-105 hover:shadow-[0_0_40px_rgba(255,255,255,0.4)] transition-all duration-500"
                >
                    {t("hero.btn.primary")}
                </a>
                <a
                    href="#showcase"
                    class="group w-full sm:w-auto px-8 py-5 bg-zinc-900/30 border border-white/40 text-white rounded-full font-['Inter'] text-sm font-bold tracking-[0.2em] uppercase hover:bg-white/10 hover:border-white transition-all duration-500 backdrop-blur-sm"
                >
                    {t("hero.btn.secondary")}
                </a>
            </div>
        </div>

        <div
            class="absolute bottom-12 left-0 right-0 z-30 flex justify-center gap-4"
        >
            <button
                class="slider-dot w-2 h-2 rounded-full bg-white transition-all duration-300 scale-150 opacity-100"
                data-index="0"
                aria-label="Slide 1"></button>
            <button
                class="slider-dot w-2 h-2 rounded-full bg-white opacity-40 transition-all duration-300 hover:opacity-100"
                data-index="1"
                aria-label="Slide 2"></button>
            <button
                class="slider-dot w-2 h-2 rounded-full bg-white opacity-40 transition-all duration-300 hover:opacity-100"
                data-index="2"
                aria-label="Slide 3"></button>
        </div>
    </section>

    <section
        class="bg-zinc-50 border-b border-zinc-200 py-32 px-4 sm:px-6 lg:px-8"
    >
        <div
            class="max-w-4xl mx-auto flex flex-col items-center text-center glide"
        >
            <div class="w-12 h-px bg-zinc-300 mb-8" aria-hidden="true"></div>
            <blockquote
                class="font-['Montserrat'] text-3xl sm:text-4xl lg:text-5xl font-medium text-zinc-800 leading-tight"
            >
                {t("quote.text")}
            </blockquote>
            <cite
                class="mt-6 not-italic font-['Inter'] text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-400"
            >
                {t("quote.author")}
            </cite>
        </div>
    </section>

    <section class="py-24 px-6 bg-white border-b border-zinc-100">
        <div class="max-w-3xl mx-auto text-center glide">
            <h2
                class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-6 tracking-tight"
            >
                {t("about.title")}
            </h2>
            <p
                class="font-['Inter'] text-lg text-zinc-600 font-light leading-relaxed"
            >
                {t("about.text")}
            </p>
        </div>
    </section>

    <section class="py-32 px-6 bg-zinc-50 border-b border-zinc-200">
        <div class="max-w-6xl mx-auto glide">
            <div class="text-center mb-20">
                <h2
                    class="font-['Montserrat'] text-4xl font-bold text-zinc-900 mb-4 tracking-tight"
                >
                    {t("capabilities.title")}
                </h2>
                <div class="w-16 h-1 bg-zinc-900 mx-auto rounded-full"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
                <div
                    class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-xl transition-shadow duration-500 border border-zinc-100 group flex flex-col justify-between h-full"
                >
                    <div>
                        <div
                            class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center mb-8 text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-500"
                        >
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"
                                ></path></svg
                            >
                        </div>
                        <h3
                            class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-4"
                        >
                            {t("capabilities.card1.title")}
                        </h3>
                    </div>
                    <p
                        class="font-['Inter'] text-zinc-600 font-medium leading-relaxed bg-zinc-50 p-4 rounded-xl"
                    >
                        {t("capabilities.card1.highlight")}
                    </p>
                </div>

                <div
                    class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-xl transition-shadow duration-500 border border-zinc-100 group flex flex-col justify-between h-full"
                >
                    <div>
                        <div
                            class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center mb-8 text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-500"
                        >
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
                                ></path></svg
                            >
                        </div>
                        <h3
                            class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-4"
                        >
                            {t("capabilities.card2.title")}
                        </h3>
                    </div>
                    <p
                        class="font-['Inter'] text-zinc-600 font-medium leading-relaxed bg-zinc-50 p-4 rounded-xl"
                    >
                        {t("capabilities.card2.highlight")}
                    </p>
                </div>

                <div
                    class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-xl transition-shadow duration-500 border border-zinc-100 group flex flex-col justify-between h-full"
                >
                    <div>
                        <div
                            class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center mb-8 text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-500"
                        >
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z"
                                ></path><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z"
                                ></path></svg
                            >
                        </div>
                        <h3
                            class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-4"
                        >
                            {t("capabilities.card3.title")}
                        </h3>
                    </div>
                    <p
                        class="font-['Inter'] text-zinc-600 font-medium leading-relaxed bg-zinc-50 p-4 rounded-xl"
                    >
                        {t("capabilities.card3.highlight")}
                    </p>
                </div>

                <div
                    class="bg-white rounded-3xl p-10 shadow-sm hover:shadow-xl transition-shadow duration-500 border border-zinc-100 group flex flex-col justify-between h-full"
                >
                    <div>
                        <div
                            class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center mb-8 text-zinc-600 group-hover:bg-zinc-900 group-hover:text-white transition-colors duration-500"
                        >
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"
                                ></path></svg
                            >
                        </div>
                        <h3
                            class="font-['Montserrat'] text-2xl font-bold text-zinc-900 mb-4"
                        >
                            {t("capabilities.card4.title")}
                        </h3>
                    </div>
                    <p
                        class="font-['Inter'] text-zinc-600 font-medium leading-relaxed bg-zinc-50 p-4 rounded-xl"
                    >
                        {t("capabilities.card4.highlight")}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section id="showcase" class="py-32 px-6 max-w-7xl mx-auto scroll-mt-20">
        <div class="mb-24 text-center glide">
            <h2
                class="font-['Montserrat'] text-4xl font-bold text-zinc-900 mb-4 tracking-tight"
            >
                {t("showcase.title")}
            </h2>
            <p class="font-['Inter'] text-zinc-500 font-light text-lg">
                {t("showcase.subtitle")}
            </p>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 auto-rows-[400px]"
        >
            {
                reorderedProjects.map((project, index) => {
                    const isExternal = project.title === "Letters from Albania";
                    const bgImage =
                        project.image ||
                        "https://images.unsplash.com/photo-1555421689-491a97ff2040?q=80&w=2940&auto=format&fit=crop";

                    // Asymmetry Logic: make the first item span 2 columns and 2 rows, others normal
                    let gridSpanClass = "col-span-1 row-span-1";
                    if (index === 0) {
                        gridSpanClass = "md:col-span-2 md:row-span-2";
                    } else if (index === 4) {
                        gridSpanClass = "md:col-span-2 lg:col-span-2";
                    }

                    return (
                        <a
                            href={
                                lang === "sq" && !isExternal
                                    ? `/sq${project.link}`
                                    : project.link
                            }
                            target={isExternal ? "_blank" : undefined}
                            rel={isExternal ? "noopener noreferrer" : undefined}
                            class={`glide group relative flex flex-col justify-end overflow-hidden bg-zinc-900 rounded-2xl hover:-translate-y-2 transition-all duration-500 hover:shadow-2xl cursor-pointer no-underline text-inherit ${gridSpanClass}`}
                        >
                            <img
                                src={bgImage}
                                alt={project.title}
                                class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-60 group-hover:scale-105 transition-transform duration-700 ease-out"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-zinc-900/90 via-zinc-900/40 to-transparent" />

                            <div class="relative z-10 p-8 md:p-10">
                                <h3
                                    class={`font-['Montserrat'] font-bold text-white mb-3 ${index === 0 ? "text-3xl md:text-5xl" : "text-2xl"}`}
                                >
                                    {lang === "sq" && project.title_sq
                                        ? project.title_sq
                                        : project.title}
                                </h3>
                                <p
                                    class={`font-['Inter'] text-zinc-300 font-light leading-relaxed mb-8 max-w-lg ${index === 0 ? "text-lg line-clamp-3" : "text-base line-clamp-2"}`}
                                >
                                    {lang === "sq" && project.description_sq
                                        ? project.description_sq
                                        : project.description}
                                </p>
                                <div class="flex items-center text-xs font-bold font-['Inter'] uppercase tracking-[0.2em] text-white/80 group-hover:text-white transition-colors duration-300 bg-white/10 w-fit px-5 py-3 rounded-full backdrop-blur-md">
                                    {t("showcase.explore")}{" "}
                                    <span class="ml-3 group-hover:translate-x-1 transition-transform duration-300">
                                        &rarr;
                                    </span>
                                </div>
                            </div>
                        </a>
                    );
                })
            }
        </div>

        <div class="mt-20 text-center glide">
            <a
                href="/cv"
                class="inline-block px-8 py-4 border border-zinc-200 text-zinc-600 rounded-full font-['Inter'] text-xs font-bold tracking-[0.2em] uppercase hover:bg-zinc-900 hover:text-white hover:border-zinc-900 transition-all duration-500"
            >
                {t("news.view_cv")}
            </a>
        </div>
    </section>

    <section
        class="py-32 px-6 bg-zinc-900 text-zinc-50 border-t border-zinc-800"
    >
        <div class="max-w-7xl mx-auto glide">
            <div class="text-center mb-20">
                <h2
                    class="font-['Montserrat'] text-4xl font-bold text-white mb-4 tracking-tight"
                >
                    {t("testimonials.title")}
                </h2>
                <div class="w-16 h-1 bg-zinc-700 mx-auto rounded-full"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div
                    class="bg-zinc-800/50 rounded-3xl p-10 border border-zinc-700/50 flex flex-col justify-between h-full hover:bg-zinc-800 transition-colors duration-500"
                >
                    <p
                        class="font-['Inter'] text-lg text-zinc-300 font-light leading-relaxed italic mb-10 relative"
                    >
                        <span
                            class="absolute -top-6 -left-4 text-6xl text-zinc-700 opacity-50 font-['Montserrat']"
                            >"</span
                        >
                        {t("testimonials.quote1.text")}
                    </p>
                    <div class="flex items-center gap-4 mt-auto">
                        <img
                            src="/images/stacie.png"
                            class="w-12 h-12 rounded-full object-cover border-2 border-zinc-700"
                            alt="Stacie Bosley"
                        />
                        <div>
                            <p
                                class="font-['Montserrat'] font-bold text-white text-sm"
                            >
                                Stacie Bosley
                            </p>
                            <p class="font-['Inter'] text-xs text-zinc-400">
                                Professor & Kahlert Chair of Economics
                            </p>
                        </div>
                    </div>
                </div>

                <div
                    class="bg-zinc-800/50 rounded-3xl p-10 border border-zinc-700/50 flex flex-col justify-between h-full hover:bg-zinc-800 transition-colors duration-500"
                >
                    <p
                        class="font-['Inter'] text-lg text-zinc-300 font-light leading-relaxed italic mb-10 relative"
                    >
                        <span
                            class="absolute -top-6 -left-4 text-6xl text-zinc-700 opacity-50 font-['Montserrat']"
                            >"</span
                        >
                        {t("testimonials.quote2.text")}
                    </p>
                    <div class="flex items-center gap-4 mt-auto">
                        <img
                            src="/images/xanthi.png"
                            class="w-12 h-12 rounded-full object-cover border-2 border-zinc-700"
                            alt="Xanthi Gerasimo"
                        />
                        <div>
                            <p
                                class="font-['Montserrat'] font-bold text-white text-sm"
                            >
                                Xanthi Gerasimo
                            </p>
                            <p class="font-['Inter'] text-xs text-zinc-400">
                                Mentor & Academic Advisor
                            </p>
                        </div>
                    </div>
                </div>

                <div
                    class="bg-zinc-800/50 rounded-3xl p-10 border border-zinc-700/50 flex flex-col justify-between h-full hover:bg-zinc-800 transition-colors duration-500"
                >
                    <p
                        class="font-['Inter'] text-lg text-zinc-300 font-light leading-relaxed italic mb-10 relative"
                    >
                        <span
                            class="absolute -top-6 -left-4 text-6xl text-zinc-700 opacity-50 font-['Montserrat']"
                            >"</span
                        >
                        {t("testimonials.quote3.text")}
                    </p>
                    <div class="flex items-center gap-4 mt-auto">
                        <img
                            src="/images/kim.png"
                            class="w-12 h-12 rounded-full object-cover border-2 border-zinc-700"
                            alt="Kim Lartz"
                        />
                        <div>
                            <p
                                class="font-['Montserrat'] font-bold text-white text-sm"
                            >
                                Kim Lartz
                            </p>
                            <p class="font-['Inter'] text-xs text-zinc-400">
                                Scenic Designer & Professor
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section
        id="contact"
        class="py-32 px-6 bg-white scroll-mt-0 border-t border-zinc-200 relative"
    >
        <div class="max-w-4xl mx-auto text-center glide">
            <h2
                class="font-['Montserrat'] text-5xl md:text-7xl font-black text-zinc-900 mb-8 tracking-tight leading-tight"
            >
                {t("contact.title")}<br />
                <span class="text-zinc-400 italic">{t("contact.title_italic")}</span>
            </h2>
            <p
                class="font-['Inter'] text-xl text-zinc-600 font-light leading-relaxed mb-12 max-w-2xl mx-auto"
            >
                {t("contact.subtitle")}
            </p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 relative">
                <!-- Toast Notification -->
                <div id="toast-notification" class="absolute -top-16 left-1/2 -translate-x-1/2 bg-green-500 text-white px-6 py-2 rounded-full font-['Inter'] text-sm font-bold tracking-wide shadow-lg opacity-0 translate-y-4 pointer-events-none transition-all duration-300 z-50 whitespace-nowrap">
                    {t("contact.copied_toast")}
                </div>

                <!-- Primary CTA -->
                <a
                    href="mailto:emmettfrett@gmail.com?subject=Let's%20Collaborate"
                    class="w-full sm:w-auto inline-flex items-center justify-center gap-4 px-10 py-5 bg-zinc-900 text-white rounded-full font-['Inter'] text-sm font-bold tracking-[0.1em] uppercase transition-all duration-500 hover:bg-zinc-800 hover:scale-105 hover:shadow-xl group"
                >
                    <span>{t("contact.btn_email")}</span>
                    <svg
                        class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-500"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
                    </svg>
                </a>
                
                <!-- Secondary CTA: Copy Email -->
                <button
                    id="copy-email-btn"
                    class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-5 border-2 border-zinc-200 text-zinc-600 bg-transparent rounded-full font-['Inter'] text-sm font-bold tracking-[0.1em] uppercase transition-all duration-500 hover:border-zinc-900 hover:text-zinc-900 hover:bg-zinc-50"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" /></svg>
                    <span>{t("contact.btn_copy")}</span>
                </button>

                <!-- Tertiary CTA: LinkedIn -->
                <a
                    href="https://www.linkedin.com/in/emmettfrett/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-5 border-2 border-zinc-200 text-zinc-600 bg-transparent rounded-full font-['Inter'] text-sm font-bold tracking-[0.1em] uppercase transition-all duration-500 hover:border-[#0A66C2] hover:text-[#0A66C2] hover:bg-[#0A66C2]/5"
                >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    <span>{t("contact.btn_linkedin")}</span>
                </a>
            </div>
        </div>

        <script is:inline>
            document.addEventListener('DOMContentLoaded', () => {
                const copyBtn = document.getElementById('copy-email-btn');
                const toast = document.getElementById('toast-notification');

                if (copyBtn && toast) {
                    copyBtn.addEventListener('click', async () => {
                        try {
                            await navigator.clipboard.writeText('emmettfrett@gmail.com');
                            
                            // Show toast
                            toast.classList.remove('opacity-0', 'translate-y-4');
                            toast.classList.add('opacity-100', 'translate-y-0');
                            
                            // Hide after 2.5s
                            setTimeout(() => {
                                toast.classList.remove('opacity-100', 'translate-y-0');
                                toast.classList.add('opacity-0', 'translate-y-4');
                            }, 2500);
                        } catch (err) {
                            console.error('Failed to copy text: ', err);
                        }
                    });
                }
            });
        </script>
    </section>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            const slider = document.getElementById("hero-slider");
            if (slider) {
                const dots = document.querySelectorAll(".slider-dot");
                const slideCount = dots.length;
                let currentIndex = 0;
                let interval;

                function goToSlide(index) {
                    slider.style.transform = `translateX(-${index * 100}%)`;
                    dots.forEach((dot, i) => {
                        if (i === index) {
                            dot.classList.replace("opacity-40", "opacity-100");
                            dot.classList.add("scale-150");
                        } else {
                            dot.classList.replace("opacity-100", "opacity-40");
                            dot.classList.remove("scale-150");
                        }
                    });
                    currentIndex = index;
                }

                function nextSlide() {
                    goToSlide((currentIndex + 1) % slideCount);
                }

                function startAutoplay() {
                    interval = setInterval(nextSlide, 5000);
                }

                function resetAutoplay() {
                    clearInterval(interval);
                    startAutoplay();
                }

                dots.forEach((dot, index) => {
                    dot.addEventListener("click", () => {
                        goToSlide(index);
                        resetAutoplay();
                    });
                });

                startAutoplay();
            }
        });
    </script>
</Layout>
