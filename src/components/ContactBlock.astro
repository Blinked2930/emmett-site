---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="py-32 px-6 bg-zinc-900 scroll-mt-0 relative">
    <div class="max-w-4xl mx-auto text-center glide">
        <h2
            class="font-['Montserrat'] text-5xl md:text-7xl font-black text-white mb-8 tracking-tight leading-tight"
        >
            {t("contact.title")}<br />
            <span class="text-zinc-400 italic">{t("contact.title_italic")}</span
            >
        </h2>
        <p
            class="font-['Inter'] text-xl text-zinc-300 font-light leading-relaxed mb-12 max-w-2xl mx-auto"
        >
            {t("contact.subtitle")}
        </p>

        <div class="flex flex-col items-center justify-center gap-8 relative">
            <div
                id="toast-notification"
                class="absolute -top-16 left-1/2 -translate-x-1/2 bg-white text-zinc-900 px-6 py-2 rounded-full font-['Inter'] text-xs font-bold tracking-[0.1em] uppercase shadow-[0_4px_24px_rgba(255,255,255,0.2)] opacity-0 translate-y-4 pointer-events-none transition-all duration-300 z-50 whitespace-nowrap"
            >
                {t("contact.copied_toast")}
            </div>

            <a
                href="mailto:emmettfrett@gmail.com?subject=Let's%20Collaborate"
                class="inline-flex items-center justify-center gap-4 px-12 py-5 bg-white text-zinc-900 rounded-full font-['Inter'] text-sm font-bold tracking-[0.2em] uppercase transition-all duration-500 hover:bg-zinc-100 hover:scale-105 hover:shadow-[0_0_40px_rgba(255,255,255,0.3)] group"
            >
                <span>{t("contact.btn_email")}</span>
                <svg
                    class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
                </svg>
            </a>

            <div
                class="flex flex-wrap items-center justify-center gap-6 sm:gap-8"
            >
                <button
                    id="copy-email-btn"
                    class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-colors duration-300 font-['Inter'] text-[11px] font-bold tracking-[0.2em] uppercase"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="2"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184"
                        ></path></svg
                    >
                    <span
                        class="border-b border-transparent group-hover:border-white transition-colors pb-0.5"
                        >{t("contact.btn_copy")}</span
                    >
                </button>

                <div class="w-1 h-1 rounded-full bg-zinc-600 hidden sm:block">
                </div>

                <a
                    href="https://www.linkedin.com/in/emmettfrett/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-2 text-zinc-400 hover:text-[#0A66C2] transition-colors duration-300 font-['Inter'] text-[11px] font-bold tracking-[0.2em] uppercase"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                        ><path
                            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                        ></path></svg
                    >
                    <span
                        class="border-b border-transparent group-hover:border-[#0A66C2] transition-colors pb-0.5"
                        >{t("contact.btn_linkedin")}</span
                    >
                </a>
            </div>
        </div>
    </div>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            const copyBtn = document.getElementById("copy-email-btn");
            const toast = document.getElementById("toast-notification");

            if (copyBtn && toast) {
                copyBtn.addEventListener("click", async () => {
                    try {
                        await navigator.clipboard.writeText(
                            "emmettfrett@gmail.com",
                        );

                        // Show toast
                        toast.classList.remove("opacity-0", "translate-y-4");
                        toast.classList.add("opacity-100", "translate-y-0");

                        // Hide after 2.5s
                        setTimeout(() => {
                            toast.classList.remove(
                                "opacity-100",
                                "translate-y-0",
                            );
                            toast.classList.add("opacity-0", "translate-y-4");
                        }, 2500);
                    } catch (err) {
                        console.error("Failed to copy text: ", err);
                    }
                });
            }
        });
    </script>
</section>
